# Configuration file for development environment

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_APP=app.py

# Server Configuration
HOST=0.0.0.0
PORT=5000

# KNN Configuration
KNN_K_NEIGHBORS=5
KNN_TEST_SIZE=0.2
KNN_RANDOM_STATE=42

# Data Configuration
DATA_FILE=data/dietary_data.json

# API Configuration
API_TIMEOUT=30
API_MAX_CONTENT_LENGTH=16777216

# CORS Configuration
CORS_ORIGINS=*

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=app.log
